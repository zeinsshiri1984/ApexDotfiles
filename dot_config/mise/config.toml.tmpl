[tools]

# LSP
rust-analyzer = "latest"
"go:golang.org/x/tools/gopls" = "latest"
"github:clangd/clangd" = "latest"
"npm:pyright" = "latest"
"npm:typescript-language-server" = "latest"
#jdtls找不到,官方脚本下

# runtime/compiler
node = "lts"
bun = "latest"
python = "3.12"
"npm:typescript" = "latest"
go = "1.23"
"java" = { version = "temurin-21", release_type = "ga" }

# Package Manager
uv = "latest"

[settings]
pipx.uvx = true
auto_install = false
legacy_version_file = false
activate_aggressive = false  # 明确行为，避免隐式 hook
experimental = true
trusted_config_paths = ["~/.config/mise"]
